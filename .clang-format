---
# Start with Google style as base
BasedOnStyle: Google
---
Language: Cpp
Standard: Latest
ColumnLimit: 100

# Bracing style
BreakBeforeBraces: Attach
InsertBraces: true

# Alignment (these differ from Google style)
AlignConsecutiveDeclarations: true
AlignConsecutiveAssignments: false
AlignConsecutiveMacros: true
AlignConsecutiveShortCaseStatements:
  Enabled: true
PointerAlignment: Left  # Rust-style references

# Line breaking (overrides from Google style)
AllowAllArgumentsOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false
AllowShortBlocksOnASingleLine: Empty
AllowShortFunctionsOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: true
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
BinPackArguments: false
BinPackParameters: false

# Break before binary operators like Rust does
BreakBeforeBinaryOperators: None

# Penalties
PenaltyBreakOpenParenthesis: 21
PenaltyBreakBeforeFirstCallParameter: 19
PenaltyBreakAssignment: 19
